# ---------------------------------------------------------------------------
# SQL Server connection
# ---------------------------------------------------------------------------
DB_DRIVER=ODBC Driver 18 for SQL Server
DB_SERVER=your-server.database.windows.net
DB_PORT=1433
DB_NAME=your-database-name
DB_USER=your-db-user
DB_PASSWORD=your-db-password
# Set to "no" for Azure SQL (it has a valid cert). "yes" for dev / self-signed.
DB_TRUST_SERVER_CERTIFICATE=no
DB_ENCRYPT=yes

# ---------------------------------------------------------------------------
# Application settings
# ---------------------------------------------------------------------------
METADATA_CONFIG_PATH=metadata_config.json
PREVIEW_ROW_LIMIT=100
EXPORT_ROW_LIMIT=500000
# Comma-separated allowed CORS origins. In production this is your App Service
# URL; in dev it's the Vite dev server.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ---------------------------------------------------------------------------
# Auth mode
#   open      — no auth (local dev, no password, no sign-in)
#   password  — shared X-App-Password header; set APP_PASSWORD below
#   azure_ad  — Azure AD via App Service EasyAuth (production)
# ---------------------------------------------------------------------------
AUTH_MODE=open
APP_PASSWORD=

# ---------------------------------------------------------------------------
# Application Insights (leave blank for local dev)
# ---------------------------------------------------------------------------
APPLICATIONINSIGHTS_CONNECTION_STRING=

# ---------------------------------------------------------------------------
# Local dev only — copy this file to .env and fill in your values.
# NEVER commit .env to source control.
# In production, set these as App Service Application Settings (env vars).
# ---------------------------------------------------------------------------
